---
/**
 * Base.astro — globales Seiten-Layout.
 * Setzt <head> (Meta/OG, Lang), bindet self-hosted Fonts + globales CSS ein
 * und rendert den Seiteninhalt über <slot/>.
 *
 * Reihenfolge der Style-Imports ist wichtig:
 *   fonts.css  -> @font-face (self-hosted, kein CDN)
 *   tokens.css -> Custom Properties (Quelle der Wahrheit)
 *   global.css -> Reset/Layout/Motion, nutzt die Tokens
 */
import "../styles/fonts.css";
import "../styles/tokens.css";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Dank Dennis — Tischler & Feldspieler",
  description = "Problem? Dank Dennis. Die persönliche Visitenkarte von Dennis: gelernter Tischler im Ladenbau und Feldspieler bei ASG Vorwärts Dessau.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
// Komponiertes Share-Bild (1200×630) aus public/og.png — absolute URL ist Pflicht,
// damit Crawler (OG/Twitter) es laden. Quelle/Composition: M12-Polish.
const ogImage = new URL("/og.png", Astro.site);
const ogImageAlt =
  "Dank Dennis — Tischler & Feldspieler. Dennis mit Daumen hoch.";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Scroll-Reveal-Gate (M11): aktiviert den versteckten Startzustand NUR, wenn JS läuft
         UND IntersectionObserver verfügbar ist (Feature-Detection). Inline im <head> →
         synchron vor dem ersten Paint → kein FOUC. Ohne JS / ohne Observer wird die Klasse
         nie gesetzt → Inhalt bleibt sofort vollständig sichtbar (Progressive Enhancement).
         Die Bewegung selbst gated zusätzlich prefers-reduced-motion in global.css. -->
    <script is:inline>
      if ("IntersectionObserver" in window) {
        document.documentElement.classList.add("js-reveal");
      }
    </script>

    <!-- Marken-Favicon (M12): „D"-Monogramm in Vereinsgelb auf Vereinsrot (public/favicon.svg). -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Dank Dennis" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter Card (fällt sonst auf og:* zurück; explizit für volle Kontrolle) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <meta name="theme-color" content="#c81e1e" />
  </head>
  <body>
    <!-- Skip-Link (A11y, M12): erste fokussierbare Stelle; springt an den Hauptinhalt.
         Visuell versteckt bis :focus (Tastatur). -->
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <slot />

    <script>
      // Scroll-Reveal-Mechanismus (M11): IntersectionObserver setzt einmalig .is-visible auf
      // [data-reveal]-Elemente. Astro bündelt das Modul client-seitig. Reagiert auf
      // prefers-reduced-motion und hat einen reveal-all-Fallback (Inhalt nie dauerhaft versteckt).
      import "../scripts/reveal.ts";
    </script>
  </body>
</html>
