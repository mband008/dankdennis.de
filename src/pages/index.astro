---
/**
 * index.astro — die One-Page.
 * M1: alle 7 Sektionen als leere Komponenten in der docs-Reihenfolge zusammengesetzt
 * (Hero → Über → Werkstatt → Fußball → Counter → Kontakt → Footer). Inhalte, Bilder und
 * Interaktionen folgen je Meilenstein (M2–M9). Tonzonen sind in den Komponenten gesetzt.
 */
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Workshop from "../components/Workshop.astro";
import Football from "../components/Football.astro";
import Counter from "../components/Counter.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Base>
  <main id="main">
    <Hero />
    <About />
    <Workshop />
    <Football />
    <Counter />
    <Contact />
  </main>
  <Footer />
</Base>
