---
/**
 * Football.astro — Sektion 4 „Abseits der Werkstatt" (Fußball).
 * M6: Text + dynamischer Bild-Hingucker (Tilt + Gelb-Akzent).
 * M10: Umbau von Einzelbild auf eine 4er-Galerie (Zwei-Kapitel-Story: Tor → Feld),
 *      echte Fotos via astro:assets (<Picture>, AVIF/WebP + srcset, lazy). Der verspielte
 *      Charakter bleibt: leichter, alternierender Tilt + Gelb-Akzentrahmen (statische
 *      Transforms → reduced-motion-neutral). Foto-Zuordnung + Alt-Texte: docs/ (Foto-Plan M10).
 * Text aus docs/dankdennis_bauplan.md §4.
 * Tonzone: rot/gelb (ASG Vorwärts Dessau) — der klar abgegrenzte Sport-Block.
 */
import { Picture } from "astro:assets";
import keepingImg from "../assets/images/Dennis_fb_keeping.png";
import gkImg from "../assets/images/Dennis_fb_gk.png";
import strikeImg from "../assets/images/Dennis_fb_strike.png";
import midfieldImg from "../assets/images/Dennis_fb_midfield.png";

// Zwei-Kapitel-Story: erst das Tor (Aufhänger: Flugparade), dann das Feld.
const shots = [
  {
    img: keepingImg,
    alt: "Dennis hält als Torwart einen Ball, Flugparade",
  },
  { img: gkImg, alt: "Dennis als Torwart in Grundstellung im Tor" },
  {
    img: strikeImg,
    alt: "Dennis am Ball im roten Trikot der ASG Vorwärts Dessau",
  },
  { img: midfieldImg, alt: "Dennis dribbelt im roten Trikot über den Platz" },
];
---

<section id="fussball" class="section tone-sport football">
  <div class="container">
    <div class="football__intro">
      <p class="kicker">ASG Vorwärts Dessau</p>
      <h2>Abseits der Werkstatt</h2>
      <p>
        Wenn ich nicht gerade säge, findet man mich auf dem Platz – im roten
        Trikot der ASG Vorwärts Dessau. Fußball ist für mich Kopf-frei-Kriegen
        und Teamgeist pur: Man verlässt sich aufeinander, jeder gibt alles, und
        am Ende zählt, was die Mannschaft schafft. Genau die Einstellung nehme
        ich mit in die Werkstatt.
      </p>
    </div>

    <div class="football__gallery">
      {
        shots.map(({ img, alt }) => (
          <figure class="football__item">
            <Picture
              src={img}
              formats={["avif", "webp"]}
              alt={alt}
              widths={[300, 600, 900]}
              sizes="(min-width: 64rem) 23vw, (min-width: 40rem) 45vw, 100vw"
              loading="lazy"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .football__intro {
    margin-bottom: var(--space-xl);
  }

  .kicker {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent); /* Gelb auf rotem Grund (tone-sport) */
    font-size: var(--fs-100);
    margin-bottom: var(--space-xs);
  }

  .football__intro h2 {
    margin-bottom: var(--space-md);
  }

  .football__intro p:not(.kicker) {
    font-size: var(--fs-300);
  }

  /* Galerie: vier Hochformat-Shots — 4-up Desktop, 2-up Tablet, einspaltig Mobil. */
  .football__gallery {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 13rem), 1fr));
  }

  .football__item {
    margin: 0;
  }

  /* Verspielter Charakter: leichter, alternierender Tilt + Gelb-Akzentrahmen.
     Statische Transforms (keine Animation) → reduced-motion-neutral. */
  .football__item :global(img) {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-md);
    box-shadow: 0 0 0 3px var(--color-yellow);
  }

  .football__item:nth-child(odd) :global(img) {
    transform: rotate(-1.5deg);
  }

  .football__item:nth-child(even) :global(img) {
    transform: rotate(1.5deg);
  }
</style>
