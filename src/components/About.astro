---
/**
 * About.astro — Sektion 2 „Über (Wer ist Dennis)".
 * M4: Split-Layout (Porträt links, Text rechts; mobil Bild oben). Heading
 * „Hi, ich bin Dennis." + 2 Absätze. Text aus docs/dankdennis_bauplan.md §2.
 * M10: echtes Werkstatt-Porträt (Carp_neutral_cam) via astro:assets (<Picture>,
 *      AVIF/WebP + srcset, lazy). Foto-Zuordnung: docs/ (Foto-Plan M10).
 * Tonzone: warm/holzig (hell). Der Bild-links/Text-rechts-Aufbau spiegelt bewusst den
 * Hero (Bild rechts) für etwas Layout-Rhythmus.
 * Im DOM steht der Text zuerst (Lesereihenfolge/A11y); auf Mobil holt CSS das Bild nach oben.
 */
import { Picture } from "astro:assets";
import aboutImg from "../assets/images/Dennis_Carp_neutral_cam.png";
---

<section id="ueber" class="section tone-warm about">
  <div class="container about__grid">
    <div class="about__text">
      <h2>Hi, ich bin Dennis.</h2>
      <p>
        Gelernter Tischler, im Hauptberuf Teil eines Schreiner-Teams im Ladenbau
        – wir bauen die Einrichtungen, die du später in Geschäften
        wiederfindest. Ich mag den Moment, in dem aus Holz und einer Idee etwas
        Echtes wird, das hält.
      </p>
      <p>
        Der Name dieser Seite? Ein alter Insider: Immer wenn irgendwo ein
        Problem gelöst war, hieß es „Dank Dennis". Irgendwann lag die Domain
        dazu auf dem Tisch – jetzt steht eben was drauf.
      </p>
    </div>

    <figure class="about__media">
      <Picture
        src={aboutImg}
        formats={["avif", "webp"]}
        alt="Dennis in seiner Werkstatt, mit Lederschürze, lächelt in die Kamera"
        widths={[400, 700, 1122]}
        sizes="(min-width: 48rem) 40vw, 100vw"
        loading="lazy"
      />
    </figure>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }

  /* Bild steht in DOM nach dem Text, soll aber immer zuerst erscheinen:
     mobil oben, auf Desktop in der linken Spalte. */
  .about__media {
    order: -1;
    margin: 0;
  }

  /* Desktop: zwei Spalten, Bild links / Text rechts (spiegelt den Hero). */
  @media (min-width: 48rem) {
    .about__grid {
      grid-template-columns: 0.9fr 1.1fr;
      gap: var(--space-2xl);
    }
  }

  .about__text p + p {
    margin-top: var(--space-md);
  }

  .about__text p {
    font-size: var(--fs-300);
  }

  .about__text h2 {
    margin-bottom: var(--space-lg);
  }

  /* Porträt (Carp_neutral_cam). Frame im Originalverhältnis 4/5 → ohne Beschnitt. */
  .about__media :global(img) {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-md);
  }
</style>
