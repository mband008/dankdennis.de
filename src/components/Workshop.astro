---
/**
 * Workshop.astro — Sektion 3 „In der Werkstatt".
 * M5: Intro (Heading + kurzer Text) über einer galerie-fähigen Bild-Struktur (auto-fit-Grid).
 * M10: vier echte Werkstatt-Action-Fotos in Prozess-Reihenfolge (zeichnen → hobeln →
 *      zusammenfügen → schleifen) via astro:assets (<Picture>, AVIF/WebP + srcset, lazy).
 *      Foto-Zuordnung + Alt-Texte: docs/ (Foto-Plan M10).
 * Text aus docs/dankdennis_bauplan.md §3.
 * Tonzone: warm/holzig (dunkel/atmosphärisch — Holz, Werkstattlicht), Gelb-Akzent.
 */
import { Picture } from "astro:assets";
import drawImg from "../assets/images/Dennis_carp_draw.png";
import planingImg from "../assets/images/Dennis_carp_planing.png";
import assembleImg from "../assets/images/Dennis_carp_assemble.png";
import grindImg from "../assets/images/Dennis_carp_grind.png";

// Prozess-Reihenfolge erzählt eine kleine Werkstatt-Geschichte.
const shots = [
  {
    img: drawImg,
    alt: "Dennis zeichnet mit Bleistift eine Linie auf ein Brett an",
  },
  { img: planingImg, alt: "Dennis hobelt ein Werkstück mit dem Handhobel" },
  {
    img: assembleImg,
    alt: "Dennis fügt eine Holzbox mit Schwalbenschwanz-Verbindung",
  },
  { img: grindImg, alt: "Dennis schleift ein Brett mit dem Exzenterschleifer" },
];
---

<section id="werkstatt" class="section tone-wood workshop">
  <div class="container">
    <div class="workshop__intro">
      <h2>In der Werkstatt</h2>
      <p>
        Vom groben Zuschnitt bis zur sauberen Verbindung: Präzision ist für mich
        kein Extra, sondern der Standard. Was ich anpacke, soll funktionieren –
        und gut aussehen.
      </p>
    </div>

    <div class="workshop__gallery">
      {
        shots.map(({ img, alt }) => (
          <figure class="workshop__item">
            <Picture
              src={img}
              formats={["avif", "webp"]}
              alt={alt}
              widths={[300, 600, 900]}
              sizes="(min-width: 64rem) 23vw, (min-width: 40rem) 45vw, 100vw"
              loading="lazy"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .workshop__intro {
    margin-bottom: var(--space-xl);
  }

  .workshop__intro h2 {
    margin-bottom: var(--space-md);
  }

  .workshop__intro p {
    font-size: var(--fs-300);
  }

  /* Galerie: Filmstrip aus vier Hochformat-Shots — 4-up auf Desktop, 2-up auf Tablet,
     einspaltig auf Mobil (auto-fit). */
  .workshop__gallery {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 13rem), 1fr));
  }

  .workshop__item {
    margin: 0;
  }

  /* Foto im Originalverhältnis 4/5 → object-fit ohne Beschnitt. */
  .workshop__item :global(img) {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-md);
  }
</style>
