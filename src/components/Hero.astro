---
/**
 * Hero.astro — Sektion 1 (Above the fold).
 * M2: Split-Layout (Text links, Bild rechts; mobil Bild oben). Headline, Untertitel,
 * Button „Dank Dennis!".
 * M3: Der Button löste per Konfetti aus; Hinweis „(probier's aus)".
 *      prefers-reduced-motion: reduce → kein Konfetti.
 * M14: Der CTA ist jetzt der Trigger des Teilen-Dialogs (data-share, aria-haspopup/
 *      -controls). Klick öffnet das <dialog> UND feuert den Konfetti-Burst (in
 *      src/scripts/share.ts, Top-Layer über dem Modal). Der confetti.ts-Import unten
 *      bleibt — er bindet weiterhin die Footer-Reprise (data-confetti).
 * M10: echtes Foto (open_hand) via astro:assets (<Picture>, AVIF/WebP + srcset).
 *      Above the fold → eager geladen. Foto-Zuordnung: docs/ (Foto-Plan M10).
 * Trägt die einzige <h1> der Seite. Inhalte aus docs/dankdennis_bauplan.md §1.
 * Tonzone: warm/holzig (hell). Im DOM steht der Text zuerst (h1 früh = A11y/SEO);
 * auf Mobil holt CSS das Bild nach oben.
 */
import { Picture } from "astro:assets";
import heroImg from "../assets/images/Dennis_neutral_open_hand.png";
---

<section id="hero" class="section tone-warm hero">
  <div class="container hero__grid">
    <div class="hero__text">
      <p class="kicker">dankdennis.de</p>
      <h1>Problem? Dank Dennis.</h1>
      <p class="hero__subtitle">
        Tischler aus Überzeugung, Fußballer aus Leidenschaft – und der Typ, der
        einfach anpackt.
      </p>
      <button
        type="button"
        class="btn hero__cta"
        data-share
        aria-haspopup="dialog"
        aria-controls="share-dialog"
      >
        Dank Dennis!
      </button>
      <p class="hero__hint">(probier's aus)</p>
    </div>

    <figure class="hero__media">
      <Picture
        src={heroImg}
        formats={["avif", "webp"]}
        alt="Dennis lächelt mit offener, einladender Handgeste"
        widths={[400, 700, 1122]}
        sizes="(min-width: 48rem) 40vw, 100vw"
        loading="eager"
        fetchpriority="high"
      />
    </figure>
  </div>
</section>

<style>
  .hero__grid {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }

  /* Desktop: zwei Spalten, Text links / Bild rechts. */
  @media (min-width: 48rem) {
    .hero__grid {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--space-2xl);
    }
  }

  .kicker {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-size: var(--fs-100);
  }

  h1 {
    font-size: var(--fs-600);
    font-weight: var(--fw-black);
    margin-block: var(--space-md) 0;
  }

  .hero__subtitle {
    font-size: var(--fs-300);
    line-height: var(--lh-normal);
    margin-block: var(--space-lg) var(--space-xl);
    color: color-mix(in srgb, currentColor 80%, transparent);
  }

  /* Button — verwendet die Tonzonen-Akzentfarbe; Konfetti-Handler folgt in M3. */
  .btn {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-300);
    color: var(--text-on-dark);
    background-color: var(--color-accent);
    border: none;
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-xl);
    transition:
      background-color var(--motion-fast) var(--ease-standard),
      transform var(--motion-fast) var(--ease-standard);
  }

  .btn:hover {
    background-color: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  .btn:active {
    transform: translateY(0);
  }

  .hero__hint {
    margin-top: var(--space-sm);
    font-size: var(--fs-100);
    /* A11y (M12): 65% statt 55% → 5.2:1 auf warmem Grund (AA ✓), bleibt aber dezent. */
    color: color-mix(in srgb, currentColor 65%, transparent);
  }

  /* Foto (foto open_hand). Frame im Originalverhältnis 4/5 → object-fit ohne Beschnitt.
   * Warm-Grade (M12): das kühle Studiobild wird NICHT per Filter aufs Gesicht verändert.
   * Stattdessen sitzt es in einem warmen Mat (Off-White → dezent amber via color-mix aus
   * Marken-Tokens) mit weichem, warmem Schatten (aus dem Espresso-Token). So gleicht sich
   * das Bild über Rahmen/Umfeld an den warmen Grund an, Hauttöne bleiben unberührt. */
  .hero__media {
    margin: 0;
    padding: var(--space-sm);
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--bg) 93%, var(--color-yellow)),
      color-mix(in srgb, var(--bg) 82%, var(--color-yellow))
    );
    border-radius: calc(var(--radius-md) + var(--space-2xs));
    box-shadow: 0 18px 40px -14px
      color-mix(in srgb, var(--bg-dark) 40%, transparent);
  }

  .hero__media :global(img) {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-md);
  }

  /* Mobil: Bild über den Text holen (docs: „Auf dem Handy: Bild oben, Text darunter"). */
  @media (max-width: 47.999rem) {
    .hero__media {
      order: -1;
    }
  }
</style>

<script>
  // Konfetti-Logik (M3): bündelt canvas-confetti und bindet den CTA. Astro bündelt
  // dieses Modul client-seitig. Reagiert auf prefers-reduced-motion (kein Konfetti).
  import "../scripts/confetti.ts";
</script>
