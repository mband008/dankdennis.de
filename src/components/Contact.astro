---
/**
 * Contact.astro — Sektion 6 „Sag Hallo".
 * M8: Text + Kontakt-Buttons. Die Kontaktwege sind noch OFFEN (siehe CLAUDE.md /
 * docs/dankdennis_bauplan.md §6) → die Buttons sind Platzhalter (data-placeholder),
 * sehen aber bereits aktiv/gebrandet aus.
 *
 * Optik (Brand-on-Hover): Outline-Pille mit Plattform-Icon in Markenfarbe; bei
 * Hover/Fokus füllt sich der Button in der jeweiligen Plattformfarbe (Instagram als
 * Verlauf). Plattformfarben kommen aus den Brand-Tokens in tokens.css. Icons sind
 * self-hosted Inline-SVGs (kein externer Request).
 * Tonzone: warm/holzig (hell).
 *
 * AKTIVIEREN (später): im contacts-Array unten je Eintrag `href` setzen — fertig.
 *   - E-Mail:    href: "mailto:dennis@dankdennis.de"
 *   - Instagram: href: "https://instagram.com/<handle>"
 *   - LinkedIn:  href: "https://www.linkedin.com/in/<handle>"
 *   - WhatsApp:  href: "https://wa.me/<nummer>"
 * Einträge mit href werden automatisch zu echten Links (target/rel für extern gesetzt),
 * solange href null ist, bleibt es ein nicht-navigierender Platzhalter.
 *
 * M10: dezentes Bild über „Sag Hallo" (hand_heart, „Danke sagen") via astro:assets
 *      (<Picture>, AVIF/WebP + srcset, lazy). Foto-Zuordnung + Alt: docs/ (Foto-Plan M10).
 */
import { Picture } from "astro:assets";
import heartImg from "../assets/images/Dennis_neutral_hand_heart.png";

type Brand = "email" | "instagram" | "linkedin" | "whatsapp";

interface Contact {
  label: string;
  brand: Brand;
  href: string | null;
}

// SVG-Pfade (viewBox 0 0 24 24). Instagram/LinkedIn/WhatsApp: Simple Icons (CC0).
const ICONS: Record<Brand, string> = {
  email:
    "M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z",
  instagram:
    "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z",
  linkedin:
    "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z",
  whatsapp:
    "M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z",
};

const contacts: Contact[] = [
  { label: "E-Mail", brand: "email", href: null },
  { label: "Instagram", brand: "instagram", href: null },
  { label: "LinkedIn", brand: "linkedin", href: null },
  { label: "WhatsApp", brand: "whatsapp", href: null },
];

const isExternal = (href: string) => href.startsWith("http");
---

<section id="kontakt" class="section tone-warm contact">
  <div class="container contact__inner">
    <figure class="contact__media" data-reveal>
      <Picture
        src={heartImg}
        formats={["avif", "webp"]}
        alt="Dennis mit der Hand auf dem Herzen, dankbare Geste"
        widths={[200, 320, 480]}
        sizes="200px"
        loading="lazy"
      />
    </figure>
    <h2 data-reveal>Sag Hallo</h2>
    <p
      class="contact__lead"
      data-reveal
      style="--reveal-delay: var(--reveal-stage)"
    >
      Lust auf einen Plausch, eine Zusammenarbeit – oder willst du einfach mal
      Danke sagen? Meld dich.
    </p>

    <ul
      class="contact__list"
      role="list"
      data-reveal
      style="--reveal-delay: var(--reveal-stage)"
    >
      {
        contacts.map(({ label, brand, href }) => {
          const klass = `contact__btn contact__btn--${brand}`;
          const icon = (
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d={ICONS[brand]} />
            </svg>
          );
          return (
            <li>
              {href ? (
                <a
                  class={klass}
                  href={href}
                  {...(isExternal(href)
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                >
                  {icon}
                  {label}
                </a>
              ) : (
                <span class={klass} data-placeholder role="link">
                  {icon}
                  {label}
                </span>
              )}
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<style>
  .contact__inner {
    text-align: center;
    display: grid;
    justify-items: center;
    gap: var(--space-md);
  }

  /* Dezentes, rundes Porträt über der Überschrift. */
  .contact__media {
    margin: 0 0 var(--space-sm);
    width: clamp(7rem, 6rem + 6vw, 11rem);
  }

  .contact__media :global(img) {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: var(--radius-pill);
  }

  .contact__lead {
    font-size: var(--fs-300);
  }

  .contact__list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-md);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  /* Brand-on-Hover-Pille. --brand wird je Plattform gesetzt (Default: Akzent). */
  .contact__btn {
    --brand: var(--color-accent);
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-200);
    text-decoration: none;
    color: var(--color-text);
    background-color: transparent;
    border: 2px solid var(--brand);
    border-radius: var(--radius-pill);
    padding: var(--space-sm) var(--space-lg);
    cursor: pointer;
    transition:
      background-color var(--motion-fast) var(--ease-standard),
      color var(--motion-fast) var(--ease-standard),
      border-color var(--motion-fast) var(--ease-standard),
      transform var(--motion-fast) var(--ease-standard);
  }

  .contact__btn svg {
    width: 1.25em;
    height: 1.25em;
    flex: none;
    fill: var(--brand); /* Icon trägt die Plattformfarbe im Ruhezustand */
    transition: fill var(--motion-fast) var(--ease-standard);
  }

  /* Hover/Fokus: Button füllt sich in der Plattformfarbe, Inhalt wird hell. */
  .contact__btn:hover,
  .contact__btn:focus-visible {
    background-color: var(--brand);
    border-color: var(--brand);
    color: var(--text-on-dark);
    transform: translateY(-2px);
  }

  .contact__btn:hover svg,
  .contact__btn:focus-visible svg {
    fill: var(--text-on-dark);
  }

  /* Plattform-Akzente (Brand-Tokens aus tokens.css). */
  .contact__btn--email {
    --brand: var(--brand-email);
  }
  .contact__btn--instagram {
    --brand: var(--brand-instagram);
  }
  .contact__btn--linkedin {
    --brand: var(--brand-linkedin);
  }
  .contact__btn--whatsapp {
    --brand: var(--brand-whatsapp);
  }

  /* Instagram füllt sich beim Hover mit dem Marken-Verlauf statt einer Vollfarbe.
     Der Rand bleibt (über --brand) Instagram-Pink — kein transparenter Rand, der
     sonst als heller Ring um die Pille aufblitzt. */
  .contact__btn--instagram:hover,
  .contact__btn--instagram:focus-visible {
    background: var(--brand-instagram-gradient);
  }
</style>
