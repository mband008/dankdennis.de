---
/**
 * Footer.astro — Sektion 7.
 * M1: schlichter Footer mit dynamischem Jahr.
 * M9: kleine Konfetti-Reprise als Easter-Egg — der Button trägt data-confetti und wird
 * vom globalen Handler (src/scripts/confetti.ts, via Hero eingebunden) automatisch
 * gebunden. prefers-reduced-motion: reduce → kein Konfetti (in confetti.ts geregelt).
 * M15: lebt jetzt global im Base-Layout → Rechts-Links (Impressum/Datenschutz) auf JEDER
 * Seite. Das Egg ist via `egg`-Prop abschaltbar (auf Rechtsseiten aus, weil dort der
 * Konfetti-Handler fehlt → toter Button vermieden).
 * M16: dezente Credit-Zeile darunter — „Made with ❤️ von Michael Banditt für seinen
 * geliebten Bruder." (Link auf michaelbanditt.de, neuer Tab, noopener).
 * Tonzone: warm/holzig (dunkel) — ruhiger Abschluss.
 */
interface Props {
  /** Konfetti-Egg zeigen? Aus, wo der Konfetti-Handler (via Hero) nicht geladen wird. */
  egg?: boolean;
}

const { egg = true } = Astro.props;
const year = new Date().getFullYear();
---

<footer id="footer" class="section tone-wood footer">
  <div class="container">
    <div class="footer__inner">
      <p class="footer__line" data-reveal>Dank Dennis · {year}</p>
      <nav class="footer__legal" aria-label="Rechtliches">
        <a href="/impressum">Impressum</a>
        <a href="/datenschutz">Datenschutz</a>
      </nav>
      {
        egg && (
          <button
            type="button"
            class="footer__egg"
            data-confetti
            data-reveal
            style="--reveal-delay: var(--reveal-stage)"
          >
            Noch ein Dank? 🎉
          </button>
        )
      }
    </div>
    <p class="footer__credit" data-reveal>
      Made with <span class="footer__heart" role="img" aria-label="Liebe"
        >❤️</span
      >
      von <a
        href="https://michaelbanditt.de"
        target="_blank"
        rel="noopener noreferrer">Michael Banditt</a
      > für seinen geliebten Bruder.
    </p>
  </div>
</footer>

<style>
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .footer__line {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
  }

  /* Rechts-Links (M15): dezent, aber klar klickbar auf dunklem Grund. */
  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    font-size: var(--fs-100);
  }

  .footer__legal a {
    text-decoration: none;
    color: inherit;
    text-underline-offset: 0.2em;
    transition: color var(--motion-fast) var(--ease-standard);
  }

  .footer__legal a:hover,
  .footer__legal a:focus-visible {
    color: var(--color-accent); /* Gelb auf dunklem Grund (tone-wood) */
    text-decoration: underline;
  }

  /* Credit-Zeile (M16): leise unter dem Footer-Row, ruhiger Abschluss. */
  .footer__credit {
    margin-top: var(--space-lg);
    font-size: var(--fs-100);
    color: color-mix(in srgb, currentColor 70%, transparent);
  }

  .footer__heart {
    /* Emoji nicht ausgrauen — Farbe bleibt voll, Text drumherum ist gedimmt. */
    color: initial;
  }

  .footer__credit a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    transition: color var(--motion-fast) var(--ease-standard);
  }

  .footer__credit a:hover,
  .footer__credit a:focus-visible {
    color: var(--color-accent); /* Gelb auf dunklem Grund (tone-wood) */
  }

  /* Kleiner Ghost-Button (Reprise des Hero-CTA), dezent auf dunklem Grund. */
  .footer__egg {
    font-family: var(--font-body);
    font-size: var(--fs-100);
    color: inherit;
    background-color: transparent;
    border: 1px solid color-mix(in srgb, currentColor 30%, transparent);
    border-radius: var(--radius-pill);
    padding: var(--space-2xs) var(--space-md);
    transition:
      border-color var(--motion-fast) var(--ease-standard),
      color var(--motion-fast) var(--ease-standard),
      transform var(--motion-fast) var(--ease-standard);
  }

  .footer__egg:hover,
  .footer__egg:focus-visible {
    color: var(--color-accent); /* Gelb auf dunklem Grund (tone-wood) */
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
</style>
